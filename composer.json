{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-pdo_pgsql": "*",
        "ext-simplexml": "*",
        "barryvdh/laravel-dompdf": "^3.1",
        "doctrine/dbal": "^3.9.4",
        "guzzlehttp/guzzle": "^7.9",
        "kalnoy/nestedset": "^6.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.6",
        "predis/predis": "^2.3",
        "pusher/pusher-php-server": "^7.2.7",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-data": "^4.18",
        "spatie/laravel-permission": "^6.16",
        "spatie/laravel-translatable": "^6.12",
        "tymon/jwt-auth": "^2.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "barryvdh/laravel-ide-helper": "^3.5",
        "beyondcode/laravel-query-detector": "^2.1",
        "dedoc/scramble": "*",
        "fakerphp/faker": "^1.23",
        "laravel-lang/lang": "^14.4",
        "laravel/sail": "^1.52",
        "laravel/telescope": "^5.6",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5.0",
        "phpunit/phpunit": "^11.0",
        "psalm/plugin-laravel": "^3.0",
        "spatie/laravel-ignition": "^2.8",
        "squizlabs/php_codesniffer": "^3.12",
        "vimeo/psalm": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/DictionaryList.php",
            "app/Helpers/TransliterationHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "app/Helpers/Helper.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
