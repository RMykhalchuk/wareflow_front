<?xml version="1.0"?>
<ruleset name="MyProject">
    <description>Налаштування правил для проєкту</description>
    <rule ref="Generic.Files.LineLength">
        <!-- Максимальна довжина рядка -->
        <properties>
            <property name="lineLimit" value="120"/>
            <!-- Ігнорувати коментарі та URL, якщо потрібно -->
            <property name="ignoreComments" value="true"/>
            <property name="ignoreUrls" value="true"/>
        </properties>
    </rule>
    <exclude-pattern>app/Services/Table/*</exclude-pattern>
    <exclude-pattern>app/Services/ParseXML</exclude-pattern>
</ruleset>
